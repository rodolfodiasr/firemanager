# ── Banco de dados ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fm_user:fm_pass@localhost:5432/firemanager
DATABASE_POOL_SIZE=10

# ── Redis / Celery ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Segurança ─────────────────────────────────────────
SECRET_KEY=troque-por-string-aleatoria-de-64-chars
CREDENTIAL_ENCRYPTION_KEY=troque-por-fernet-key-base64
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Anthropic (IA) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4000

# ── Servidor ──────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
API_PORT=8000

# ── E-mail (notificações) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@sua-empresa.com
SMTP_PASSWORD=sua_senha_de_app
EMAIL_FROM=FireManager <noreply@sua-empresa.com>

# ── Testes de integração (opcional) ───────────────────
FORTINET_TEST_HOST=https://192.168.1.1
FORTINET_TEST_TOKEN=seu_token_de_teste
SONICWALL_TEST_HOST=https://192.168.1.2
SONICWALL_TEST_TOKEN=seu_token_de_teste

# ── Bridge ────────────────────────────────────────────
BRIDGE_MTLS_CERT_PATH=/certs/bridge.crt
BRIDGE_MTLS_KEY_PATH=/certs/bridge.key
BRIDGE_SERVER_CA_PATH=/certs/server-ca.crt
